<%
  mood_colors_dash = {
    "feliz"=>"#9affab","euforico"=>"#56eb00","apaixonado"=>"#cc1479","romantico"=>"#ff8fc3",
    "confiante"=>"#ffc400","sortudo"=>"#00e887","confortavel"=>"#b3e6b3","triste"=>"#478bc7",
    "deprimido"=>"#5a5aa0","entediado"=>"#888888","estressado"=>"#ff7a46","irritado"=>"#dd1c1c",
    "bravo"=>"#ff2f2f","assustado"=>"#c0d31a","cansado"=>"#415658","envergonhado"=>"#7e39da",
    "doente"=>"#75975e","azarado"=>"#3f3f3f","sujo"=>"#81673e"
  } unless defined?(mood_colors_dash)

  mood_labels_dash = {
    "feliz"=>"Feliz","euforico"=>"Eufórico","apaixonado"=>"Apaixonado","romantico"=>"Romântico",
    "confiante"=>"Confiante","sortudo"=>"Sortudo","confortavel"=>"Confortável","triste"=>"Triste",
    "deprimido"=>"Deprimido","entediado"=>"Entediado","estressado"=>"Estressado","irritado"=>"Irritado",
    "bravo"=>"Bravo","assustado"=>"Assustado","cansado"=>"Cansado","envergonhado"=>"Envergonhado",
    "doente"=>"Doente","azarado"=>"Azarado","sujo"=>"Sujo"
  } unless defined?(mood_labels_dash)

  latest = current_user.emotions.order(created_at: :desc).first
  latest_mood = latest&.mood.to_s.downcase.strip
  latest_color = @mood_colors_dash[latest_mood] || "var(--sims-teal-light)"
  latest_label = @mood_labels_dash[latest_mood] || "—"
%>

<div class="sims-container">

  <div class="dashboard-welcome">
    <%= render "shared/logo", size: "lg" %>
    <h1 class="dashboard-welcome-name mt-2">Olá, <%= current_user.display_name %>!</h1>
    <p class="dashboard-welcome-sub">Como você está se sentindo hoje?</p>
  </div>

  <div class="dashboard-grid">

    <%# Card: emoção atual %>
    <div class="sims-panel" style="text-align:center;">
      <p class="sims-panel-title">Agora eu estou…</p>

      <% if latest %>
        <img src="/assets/emocoes/<%= latest_mood %>-Photoroom.png"
             onerror="this.src='/assets/emocoes/<%= latest_mood %>.png'"
             style="width:100px; height:100px; object-fit:contain; display:block; margin:0 auto 0.75rem; filter:drop-shadow(0 6px 20px rgba(0,0,0,0.5));"
             alt="<%= latest_label %>">
        <span style="display:inline-block; padding:0.35rem 1.1rem; border-radius:20px; font-size:0.95rem; font-weight:900; background:<%= latest_color %>22; color:<%= latest_color %>; border:1.5px solid <%= latest_color %>44; margin-bottom:0.75rem;">
          <%= latest_label %>
        </span>
        <p style="font-size:0.75rem; color:var(--sims-text-muted);">
          Intensidade: <%= latest.intensity %>/10
        </p>
        <p style="font-size:0.75rem; color:var(--sims-text-muted); margin-bottom:1rem;">
          <%= (latest.recorded_at || latest.created_at).strftime("%d/%m às %H:%M") %>
        </p>
        <%= link_to "Ver registro", emotion_path(latest), class: "sims-btn sims-btn-primary" %>
      <% else %>
        <div style="font-size:3rem; margin:1rem 0;">🌱</div>
        <p style="font-size:0.85rem; color:var(--sims-text-muted); margin-bottom:1rem;">Ainda sem registros</p>
        <%= link_to "+ Registrar agora", new_emotion_path, class: "sims-btn sims-btn-primary" %>
      <% end %>
    </div>

    <%# Card: histórico recente %>
    <div class="sims-panel">
      <p class="sims-panel-title">Últimas emoções</p>

      <% recent = current_user.emotions.order(created_at: :desc).limit(4) %>
      <% if recent.any? %>
        <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:1.25rem;">
          <% recent.each do |emotion| %>
            <% m = emotion.mood.to_s.downcase.strip
               c = mood_colors_dash[m] || "var(--sims-teal)"
               l = mood_labels_dash[m] || m.capitalize %>
            <%= link_to emotion_path(emotion), style:"text-decoration:none;" do %>
              <div style="display:flex; align-items:center; gap:10px; padding:8px 12px; background:rgba(0,0,0,0.2); border-radius:10px; border-left:3px solid <%= c %>; transition:background 0.2s;" onmouseover="this.style.background='rgba(0,0,0,0.35)'" onmouseout="this.style.background='rgba(0,0,0,0.2)'">
                <img src="/assets/emocoes/<%= m %>-Photoroom.png"
                     onerror="this.src='/assets/emocoes/<%= m %>.png'"
                     style="width:36px; height:36px; object-fit:contain;"
                     alt="<%= l %>">
                <div style="flex:1; min-width:0;">
                  <div style="font-weight:800; font-size:0.88rem; color:<%= c %>;"><%= l %></div>
                  <% if emotion.note.present? %>
                    <div style="font-size:0.72rem; color:var(--sims-text-muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= emotion.note %></div>
                  <% end %>
                </div>
                <span style="font-size:0.7rem; color:var(--sims-text-muted); flex-shrink:0;"><%= (emotion.recorded_at || emotion.created_at).strftime("%d/%m") %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p style="font-size:0.85rem; color:var(--sims-text-muted); margin-bottom:1.25rem;">Nenhuma emoção registrada ainda.</p>
      <% end %>

      <div class="action-row">
        <%= link_to "+ Registrar", new_emotion_path, class: "sims-btn sims-btn-primary" %>
        <%= link_to "Ver todas", emotions_path, class: "sims-btn sims-btn-ghost" %>
      </div>
    </div>

    <%# Card: bem-estar %>
    <div class="sims-panel">
      <p class="sims-panel-title">Bem-estar</p>
      <p style="font-size:0.9rem; color:var(--sims-text-muted); line-height:1.6; margin-bottom:1.25rem;">
        O SONA está aqui para te ajudar a entender seus sentimentos e te conectar com profissionais de saúde mental em Mossoró.
      </p>
      <div class="mood-bar" style="display:flex; flex-wrap:wrap; gap:6px;">
        <% [["feliz","Feliz","#FFE135"],["sortudo","Sortudo","#00e8a8"],["confiante","Confiante","#ff8c00"],
            ["triste","Triste","#5b8db8"],["estressado","Estressado","#ff4444"]].each do |key, lbl, clr| %>
          <%= link_to new_emotion_path, style:"text-decoration:none;" do %>
            <span style="display:inline-flex; align-items:center; gap:5px; padding:4px 12px; border-radius:20px; background:<%= clr %>18; color:<%= clr %>; border:1px solid <%= clr %>44; font-size:0.78rem; font-weight:800; cursor:pointer;">
              <img src="/assets/emocoes/<%= key %>-Photoroom.png"
                   onerror="this.src='/assets/emocoes/<%= key %>.png'"
                   style="width:20px;height:20px;object-fit:contain;">
              <%= lbl %>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>

  </div>
</div>
