<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <%= render "shared/logo", size: "lg" %>
      <h1 class="auth-title">Criar conta</h1>
      <p class="auth-subtitle">Comece sua jornada no SONA</p>
    </div>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
        <div class="sims-form-group">
          <%= f.label :first_name, "Nome", class: "sims-label" %>
          <%= f.text_field :first_name, autofocus: true, class: "sims-input", placeholder: "Ana" %>
        </div>
        <div class="sims-form-group">
          <%= f.label :last_name, "Sobrenome", class: "sims-label" %>
          <%= f.text_field :last_name, class: "sims-input", placeholder: "Silva" %>
        </div>
      </div>
      <div class="sims-form-group">
        <%= f.label :email, "E-mail", class: "sims-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "sims-input", placeholder: "seu@email.com" %>
      </div>
      <div class="sims-form-group">
        <%= f.label :password, "Senha", class: "sims-label" %>
        <% if @minimum_password_length %>
          <span style="font-size:0.72rem; color:var(--sims-text-muted); display:block; margin-bottom:4px;">Minimo <%= @minimum_password_length %> caracteres</span>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "sims-input", placeholder: "••••••••" %>
      </div>
      <div class="sims-form-group">
        <%= f.label :password_confirmation, "Confirmar senha", class: "sims-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "sims-input", placeholder: "••••••••" %>
      </div>
      <%= f.submit "Criar conta", class: "sims-btn sims-btn-plumbob sims-btn-full" %>
    <% end %>
    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
