<div class="sims-container-sm">
  <div class="sims-page-header">
    <div>
      <h1 class="sims-page-title">Editar perfil</h1>
      <p class="sims-page-subtitle">Atualize suas informacoes</p>
    </div>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="sims-panel" style="margin-bottom:1.25rem;">
      <p class="sims-panel-title">Informacoes pessoais</p>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
        <div class="sims-form-group">
          <%= f.label :first_name, "Nome", class: "sims-label" %>
          <%= f.text_field :first_name, class: "sims-input" %>
        </div>
        <div class="sims-form-group">
          <%= f.label :last_name, "Sobrenome", class: "sims-label" %>
          <%= f.text_field :last_name, class: "sims-input" %>
        </div>
      </div>
      <div class="sims-form-group">
        <%= f.label :email, "E-mail", class: "sims-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "sims-input" %>
      </div>
    </div>

    <div class="sims-panel" style="margin-bottom:1.25rem;">
      <p class="sims-panel-title">Alterar senha</p>
      <p style="font-size:0.8rem; color:var(--sims-text-muted); margin-bottom:1rem;">Deixe em branco para manter a senha atual</p>
      <div class="sims-form-group">
        <%= f.label :password, "Nova senha", class: "sims-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "sims-input", placeholder: "Nova senha (opcional)" %>
      </div>
      <div class="sims-form-group">
        <%= f.label :password_confirmation, "Confirmar nova senha", class: "sims-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "sims-input", placeholder: "Confirmar nova senha" %>
      </div>
      <div class="sims-form-group">
        <%= f.label :current_password, "Senha atual", class: "sims-label" %>
        <span style="font-size:0.75rem; color:var(--sims-text-muted); display:block; margin-bottom:4px;">Necessaria para confirmar qualquer alteracao</span>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "sims-input", placeholder: "Sua senha atual" %>
      </div>
    </div>

    <div class="action-row">
      <%= f.submit "Salvar alteracoes", class: "sims-btn sims-btn-primary" %>
      <%= link_to "Cancelar", dashboard_path, class: "sims-btn sims-btn-ghost" %>
    </div>
  <% end %>

  <div class="sims-panel mt-3" style="border-color:rgba(255,45,45,0.2);">
    <p class="sims-panel-title" style="color:#ff6060;">Zona de perigo</p>
    <p style="font-size:0.85rem; margin-bottom:1rem;">Excluir permanentemente sua conta e todos os dados.</p>
    <%= button_to "Excluir minha conta", registration_path(resource_name), method: :delete,
        data: { confirm: "Tem certeza? Esta acao nao pode ser desfeita." },
        class: "sims-btn sims-btn-danger" %>
  </div>
</div>
