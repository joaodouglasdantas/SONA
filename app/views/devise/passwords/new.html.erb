<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <%= render "shared/logo", size: "lg" %>
      <h1 class="auth-title">Recuperar senha</h1>
      <p class="auth-subtitle">Enviaremos um link por e-mail</p>
    </div>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="sims-form-group">
        <%= f.label :email, "E-mail", class: "sims-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "sims-input", placeholder: "seu@email.com" %>
      </div>
      <%= f.submit "Enviar instrucoes", class: "sims-btn sims-btn-primary sims-btn-full" %>
    <% end %>
    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
