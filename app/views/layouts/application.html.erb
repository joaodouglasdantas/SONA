<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "SONA" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="SONA">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "sims", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "emotions", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <nav class="sims-nav">
        <a href="<%= dashboard_path %>" class="sims-nav-brand">
          <%= render "shared/logo", size: "sm" %>
          SONA
        </a>
        <div class="sims-nav-links">
          <%= link_to "Dashboard", dashboard_path, class: "sims-nav-link #{'active' if controller_name == 'dashboard'}" %>

          <%= link_to "Emocoes", emotions_path, class: "sims-nav-link #{'active' if controller_name == 'emotions'}" %>
        </div>
        <div class="sims-nav-user">
          <span class="sims-nav-user-name"><%= current_user.display_name %></span>
          <%= button_to "Sair", destroy_user_session_path, method: :delete,
                        class: "sims-btn sims-btn-ghost",
                        style: "font-size:0.8rem; padding:5px 14px;" %>
        </div>
      </nav>
    <% end %>

    <% if notice.present? %>
      <div class="sims-flash sims-flash-notice" data-flash><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="sims-flash sims-flash-alert" data-flash><%= alert %></div>
    <% end %>
    <script>
      document.querySelectorAll('[data-flash]').forEach(function(el) {
        setTimeout(function() {
          el.classList.add('sims-flash-hidden');
          setTimeout(function() { el.remove(); }, 400);
        }, 3500);
      });
    </script>

    <%= yield %>
  </body>
</html>
