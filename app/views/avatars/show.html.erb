<div class="sims-container">

  <div class="sims-page-header">
    <%= render "shared/logo", size: "lg" %>
    <div>
      <h1 class="sims-page-title">Meu Sim</h1>
      <p class="sims-page-subtitle">Seu personagem no mundo SONA</p>
    </div>
  </div>

  <div class="avatar-page">

    <turbo-frame id="avatar-status-frame"
                 <%= "src=\"#{avatar_status_path}\"".html_safe if current_user.avatar_generating? %>>
      <%= render "avatar_status_frame" %>
    </turbo-frame>

    <div style="display:flex; flex-direction:column; gap:1.25rem;">

      <% if current_user.original_photo.attached? && current_user.sims_avatar.attached? %>
        <div class="sims-panel">
          <p class="sims-panel-title">Original vs Sim</p>
          <div class="avatar-compare">
            <div class="avatar-compare-item">
              <p class="avatar-compare-label">Foto Real</p>
              <%= image_tag url_for(current_user.original_photo), class: "avatar-compare-img", alt: "Original" %>
            </div>
            <div class="avatar-compare-item">
              <p class="avatar-compare-label">The Sims</p>
              <%= image_tag url_for(current_user.sims_avatar), class: "avatar-compare-img sims-style", alt: "Sims" %>
            </div>
          </div>
        </div>
      <% end %>

      <div class="sims-panel">
        <p class="sims-panel-title">Status do Sim</p>
        <div style="display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.85rem; color:var(--sims-text-muted);">Nome do Sim</span>
            <span style="font-weight:800; color:var(--sims-white);"><%= current_user.sim_display_name %></span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.85rem; color:var(--sims-text-muted);">Foto enviada</span>
            <span style="font-weight:800; color:<%= current_user.original_photo.attached? ? 'var(--plumbob)' : 'var(--sims-text-muted)' %>">
              <%= current_user.original_photo.attached? ? "Sim" : "Nao" %>
            </span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.85rem; color:var(--sims-text-muted);">Avatar gerado</span>
            <% status_color = case current_user.avatar_generation_status
                              when "done"       then "var(--plumbob)"
                              when "generating" then "var(--sims-teal-light)"
                              when "failed"     then "#ff6060"
                              else "var(--sims-text-muted)"
                              end %>
            <% status_label = case current_user.avatar_generation_status
                              when "done"       then "Pronto"
                              when "generating" then "Gerando..."
                              when "failed"     then "Falhou"
                              else "Pendente"
                              end %>
            <span style="font-weight:800; color:<%= status_color %>;"><%= status_label %></span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.85rem; color:var(--sims-text-muted);">Emocoes registradas</span>
            <span style="font-weight:800; color:var(--sims-teal-light);"><%= current_user.emotions.count %></span>
          </div>
        </div>
      </div>

      <% unless current_user.sims_avatar.attached? || current_user.avatar_generating? %>
        <div class="sims-panel" style="border-color: rgba(127,232,64,0.3);">
          <p class="sims-panel-title" style="color:var(--plumbob);">Proximos passos</p>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <% unless current_user.original_photo.attached? %>
              <div style="display:flex; align-items:center; gap:10px;">
                <span style="color:var(--plumbob); font-size:1.2rem;">1.</span>
                <span style="font-size:0.9rem;">
                  <%= link_to "Envie sua foto", edit_avatar_path, style: "color:var(--sims-teal-light); font-weight:700;" %>
                  para criar seu avatar
                </span>
              </div>
            <% end %>
            <% if current_user.original_photo.attached? && !current_user.sims_avatar.attached? %>
              <div style="display:flex; align-items:center; gap:10px;">
                <span style="color:var(--plumbob); font-size:1.2rem;">2.</span>
                <span style="font-size:0.9rem;">Clique em <strong style="color:var(--plumbob);">Gerar Avatar</strong> para a magica acontecer</span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if current_user.sims_avatar.attached? %>
        <div class="sims-panel" style="border-color:rgba(255,45,45,0.2);">
          <p class="sims-panel-title" style="color:#ff6060;">Zona de perigo</p>
          <p style="font-size:0.85rem; margin-bottom:1rem;">Remover o avatar Sims gerado. Voce podera gerar um novo depois.</p>
          <%= button_to "Remover Avatar",
                        avatar_path,
                        method: :patch,
                        params: { remove_sims_avatar: true },
                        data: { confirm: "Tem certeza? O avatar sera removido." },
                        class: "sims-btn sims-btn-danger" %>
        </div>
      <% end %>

    </div>
  </div>

</div>
