<% content_for :title, "Meu Sim — #{current_user.sim_display_name}" %>

<div class="sims-container">

  <div class="sims-page-header">
    <%= render "shared/plumbob", size: "lg" %>
    <div>
      <h1 class="sims-page-title">Meu Sim</h1>
      <p class="sims-page-subtitle">Seu personagem no mundo SONA</p>
    </div>
  </div>

  <div class="avatar-page">

    <!-- Coluna esquerda: Card do Sim -->
    <div class="sims-panel avatar-card">
      <div class="avatar-header">
        <%= render "shared/plumbob" %>
        <h2 class="avatar-sim-name"><%= current_user.sim_display_name %></h2>
        <span class="avatar-sim-subtitle">Sim de <%= current_user.first_name %></span>
      </div>

      <% if current_user.sims_avatar.attached? %>
        <div class="avatar-image-wrapper">
          <%= image_tag url_for(current_user.sims_avatar),
                        class: "avatar-image avatar-image-sims",
                        alt: "Avatar Sims de #{current_user.sim_display_name}" %>
          <span class="avatar-badge">💎 Sim</span>
        </div>
      <% elsif current_user.original_photo.attached? %>
        <div class="avatar-image-wrapper">
          <%= image_tag url_for(current_user.original_photo),
                        class: "avatar-image",
                        alt: "Foto de #{current_user.first_name}" %>
        </div>
      <% else %>
        <div class="avatar-placeholder">
          <span class="avatar-placeholder-icon">🧍</span>
          <span>Sem avatar</span>
          <span style="font-size:0.75rem; opacity:0.6">Envie sua foto!</span>
        </div>
      <% end %>

      <!-- Humores do Sims -->
      <div class="mood-bar mt-3">
        <span class="mood-chip mood-chip-feliz">😊 Feliz</span>
        <span class="mood-chip mood-chip-animado">⚡ Animado</span>
        <span class="mood-chip mood-chip-inspirado">✨ Inspirado</span>
        <span class="mood-chip mood-chip-confiante">💪 Confiante</span>
        <span class="mood-chip mood-chip-concentrado">🔮 Concentrado</span>
        <span class="mood-chip mood-chip-paqueador">💕 Paqueador</span>
        <span class="mood-chip mood-chip-furioso">😤 Furioso</span>
        <span class="mood-chip mood-chip-triste">😢 Triste</span>
        <span class="mood-chip mood-chip-entediado">😑 Entediado</span>
      </div>

      <hr class="sims-divider">

      <div class="action-row">
        <%= link_to edit_avatar_path, class: "sims-btn sims-btn-ghost" do %>
          ✏️ Editar Sim
        <% end %>

        <% if current_user.original_photo.attached? && !current_user.sims_avatar.attached? %>
          <%= button_to generate_avatar_path, method: :post,
                         class: "sims-btn sims-btn-plumbob",
                         data: { action: "click->avatar#generate" } do %>
            💎 Gerar Avatar Sims
          <% end %>
        <% elsif current_user.sims_avatar.attached? %>
          <%= button_to generate_avatar_path, method: :post,
                         class: "sims-btn sims-btn-ghost",
                         data: { confirm: "Gerar um novo avatar substituirá o atual. Continuar?" } do %>
            🔄 Regerar Avatar
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Coluna direita: Painel de info + comparativo -->
    <div style="display:flex; flex-direction:column; gap:1.25rem;">

      <!-- Comparativo original vs sims -->
      <% if current_user.original_photo.attached? && current_user.sims_avatar.attached? %>
        <div class="sims-panel">
          <p class="sims-panel-title">📸 Original vs Sim</p>
          <div class="avatar-compare">
            <div class="avatar-compare-item">
              <p class="avatar-compare-label">Foto Real</p>
              <%= image_tag url_for(current_user.original_photo),
                            class: "avatar-compare-img",
                            alt: "Foto original" %>
            </div>
            <div class="avatar-compare-item">
              <p class="avatar-compare-label">💎 The Sims</p>
              <%= image_tag url_for(current_user.sims_avatar),
                            class: "avatar-compare-img sims-style",
                            alt: "Avatar Sims" %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Status do Sim -->
      <div class="sims-panel">
        <p class="sims-panel-title">📊 Status do Sim</p>

        <div style="display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.85rem; color:var(--sims-text-muted);">Nome do Sim</span>
            <span style="font-weight:800; color:var(--sims-white);">
              <%= current_user.sim_display_name %>
            </span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.85rem; color:var(--sims-text-muted);">Foto enviada</span>
            <span style="font-weight:800; color:<%= current_user.original_photo.attached? ? 'var(--plumbob)' : 'var(--sims-text-muted)' %>">
              <%= current_user.original_photo.attached? ? "✅ Sim" : "❌ Não" %>
            </span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.85rem; color:var(--sims-text-muted);">Avatar Sims gerado</span>
            <span style="font-weight:800; color:<%= current_user.sims_avatar.attached? ? 'var(--plumbob)' : 'var(--sims-text-muted)' %>">
              <%= current_user.sims_avatar.attached? ? "💎 Pronto!" : "⏳ Pendente" %>
            </span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.85rem; color:var(--sims-text-muted);">Emoções registradas</span>
            <span style="font-weight:800; color:var(--sims-teal-light);">
              <%= current_user.emotions.count %>
            </span>
          </div>
        </div>
      </div>

      <!-- Próximos passos -->
      <% unless current_user.original_photo.attached? && current_user.sims_avatar.attached? %>
        <div class="sims-panel" style="border-color: rgba(127,232,64,0.3);">
          <p class="sims-panel-title" style="color:var(--plumbob);">💡 Próximos passos</p>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <% unless current_user.original_photo.attached? %>
              <div style="display:flex; align-items:center; gap:10px;">
                <span style="color:var(--plumbob); font-size:1.2rem;">①</span>
                <span style="font-size:0.9rem;">
                  <%= link_to "Envie sua foto", edit_avatar_path, style: "color:var(--sims-teal-light); font-weight:700;" %>
                  para criar seu avatar Sims
                </span>
              </div>
            <% end %>
            <% if current_user.original_photo.attached? && !current_user.sims_avatar.attached? %>
              <div style="display:flex; align-items:center; gap:10px;">
                <span style="color:var(--plumbob); font-size:1.2rem;">②</span>
                <span style="font-size:0.9rem;">Clique em <strong style="color:var(--plumbob);">💎 Gerar Avatar Sims</strong> para a mágica acontecer!</span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div><!-- /coluna direita -->
  </div><!-- /avatar-page -->

</div>

<!-- Overlay de carregamento (ativado pelo JS ao clicar em Gerar) -->
<div class="generating-overlay" id="generatingOverlay">
  <svg class="plumbob plumbob-lg plumbob-spin" viewBox="0 0 100 115" xmlns="http://www.w3.org/2000/svg">
    <polygon points="50,5 95,52 50,99 5,52" fill="#7fe840"/>
    <polygon points="50,5 95,52 50,52"       fill="#a8ff60" opacity="0.85"/>
    <polygon points="50,5 5,52 50,52"         fill="#5bc830" opacity="0.85"/>
    <polygon points="50,99 95,52 50,52"       fill="#3d9e1e" opacity="0.9"/>
    <polygon points="50,99 5,52 50,52"        fill="#2e7a15" opacity="0.9"/>
  </svg>
  <p class="generating-text">Criando seu Sim... 💎</p>
  <p style="font-size:0.8rem; color:var(--sims-text-muted);">Isso pode levar alguns segundos</p>
</div>

<script>
  document.querySelectorAll('form[action*="generate"]').forEach(form => {
    form.addEventListener('submit', () => {
      document.getElementById('generatingOverlay').classList.add('active');
    });
  });
</script>
