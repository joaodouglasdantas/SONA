<%# app/views/emotions/index.html.erb %>
<% content_for :title, "Minhas Emoções — SONA" %>

<%
  mood_colors_idx = {
    "feliz"        => "#FFE135", "euforico"     => "#7fe840",
    "apaixonado"   => "#ff6ebf", "romantico"    => "#ff8fab",
    "confiante"    => "#ff8c00", "sortudo"      => "#00e8a8",
    "confortavel"  => "#a8edea", "triste"       => "#5b8db8",
    "deprimido"    => "#6a6a9c", "entediado"    => "#888888",
    "estressado"   => "#ff4444", "irritado"     => "#ff2d2d",
    "bravo"        => "#ff0000", "assustado"    => "#9b59b6",
    "cansado"      => "#6b8c42", "envergonhado" => "#e07b54",
    "doente"       => "#6db33f", "azarado"      => "#b8860b",
    "sujo"         => "#a0855b"
  }

  mood_labels_idx = {
    "feliz"=>"Feliz","euforico"=>"Eufórico","apaixonado"=>"Apaixonado",
    "romantico"=>"Romântico","confiante"=>"Confiante","sortudo"=>"Sortudo",
    "confortavel"=>"Confortável","triste"=>"Triste","deprimido"=>"Deprimido",
    "entediado"=>"Entediado","estressado"=>"Estressado","irritado"=>"Irritado",
    "bravo"=>"Bravo","assustado"=>"Assustado","cansado"=>"Cansado",
    "envergonhado"=>"Envergonhado","doente"=>"Doente","azarado"=>"Azarado","sujo"=>"Sujo"
  }
%>

<div class="emotion-index-page">
  <div class="emotion-index-header">
    <h1 class="emotion-index-title">Minhas Emoções</h1>
    <%= link_to "+ Registrar", new_emotion_path, class: "sims-btn sims-btn-primary" %>
  </div>

  <% if @emotions.empty? %>
    <div class="emotion-empty-state">
      <p style="font-size:3rem;">🌱</p>
      <p>Você ainda não registrou nenhuma emoção.</p>
      <%= link_to "Registrar agora", new_emotion_path, class: "sims-btn sims-btn-primary" %>
    </div>
  <% else %>
    <div class="emotion-timeline">
      <% @emotions.each do |emotion| %>
        <% mood = emotion.mood.to_s.downcase.strip
           color = mood_colors_idx[mood] || "#00c38c"
           label = mood_labels_idx[mood] || mood.capitalize
        %>
        <%= link_to emotion_path(emotion), class: "emotion-timeline-item", data: { mood: mood } do %>
          <img src="/emocoes/<%= mood %>-Photoroom.png"
               onerror="this.src='/emocoes/<%= mood %>.png'"
               class="emotion-timeline-sim"
               alt="<%= label %>">

          <div class="emotion-timeline-body">
            <div class="emotion-timeline-mood" style="color: <%= color %>;">
              <%= label %>
            </div>
            <div class="emotion-timeline-note">
              <%= emotion.note.present? ? emotion.note : "Sem anotação" %>
            </div>
          </div>

          <div class="emotion-timeline-meta">
            <span class="emotion-timeline-date">
              <%= (emotion.recorded_at || emotion.created_at).strftime("%d/%m · %H:%M") %>
            </span>
            <span class="emotion-intensity-pill" style="color:<%= color %>; background:<%= color %>18;">
              <%= emotion.intensity %>/10
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
