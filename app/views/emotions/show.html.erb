<h1>Emoção — <%= @emotion.recorded_at.strftime("%d/%m/%Y às %H:%M") %></h1>

<p><strong>Emoção:</strong> <%= @emotion.mood %></p>
<p><strong>Intensidade:</strong> <%= @emotion.intensity %>/10</p>
<p><strong>Anotação:</strong> <%= @emotion.note.presence || "Nenhuma anotação." %></p>

<%= link_to "Voltar", emotions_path %>